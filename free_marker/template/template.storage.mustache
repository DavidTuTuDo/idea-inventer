rules_version = '2';
service firebase.storage {
    match /b/{bucket}/o {

    function isSignIn(){
        return  request.auth != null;
    }

    function alwaysTrue() {
        return true;
    }

    function alwaysFalse() {
       return false;
    }

   function isAuthorOfDionysus(id) {
      return request.auth != null && firestore.get(/databases/(default)/documents/dionysus/$(id)).data.idOfAuthor == request.auth.uid;
    }

    function isAdmin() {
      return request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function sizeLowerThan2MB() {
      return request.resource.size < 2 * 1024 * 1024;
    }

    function sizeLowerThan5MB() {
        return request.resource.size < 5 * 1024 * 1024;
    }

    function sizeLowerThan20MB() {
        return request.resource.size < 20 * 1024 * 1024;
    }

    function sizeLowerThan25MB() {
        return request.resource.size < 25 * 1024 * 1024;
    }

    function sizeLowerThan30MB() {
        return request.resource.size < 30 * 1024 * 1024;
    }


match /public/{fileId} {
allow write: if isAdmin() && sizeLowerThan5MB()
allow read: if alwaysTrue()
}

/** --- documents--- **/

    }
}
