rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {

        function isSelf(uid){
            return request.auth.uid == uid;
        }

        function isAllowRead(){
            return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.allowRead == true;
        }

        function withoutCopyright(){
            return resource.data.copyright == false;
        }

        function isDocumentUser() {
            return request.auth != null && resource.data.idOfUser == request.auth.uid;
        }

        function isAuthorEitherUser() {
            return isAuthor() || isDocumentUser();
        }

        function isAuthorNSelf(uid) {
            return isAuthor() && isSelf(uid);
        }

        function isAuthorOfDionysus(id) {
            return request.auth != null && get(/databases/$(database)/documents/dionysus/$(id)).data.idOfAuthor == request.auth.uid;
        }

        function isAdmin() {
            return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
        }

        function isAuthor() {
            return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthor == true;
        }

        function isSignIn() {
            return request.auth.uid != null;
        }

        function userInfoExist() {
            return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
        }

        function alwaysTrue() {
            return true;
        }

        function alwaysFalse() {
            return false;
        }

        function isPublicDocument() {
            return resource.data.visibility == 'public';
        }

         function isMyDocument() {
            let data = resource.data;
            let isAnonymous = data.get('anonymous', false) == true;
            let isOwner = request.auth != null && (data.idOfUser == request.auth.uid || data.idOfAuthor == request.auth.uid);
            return isAnonymous || isOwner;
        }

        /** --- documents--- **/

    }
}
