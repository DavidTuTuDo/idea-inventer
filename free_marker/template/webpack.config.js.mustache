const path = require("path");
const webpack = require("webpack");
const HtmlWebpackPlugin = require("html-webpack-plugin");
const TerserPlugin = require("terser-webpack-plugin");
const MiniCssExtractPlugin = require("mini-css-extract-plugin");
const BundleAnalyzerPlugin = require("webpack-bundle-analyzer").BundleAnalyzerPlugin;
const CompressionPlugin = require("compression-webpack-plugin");

// 載入我們在步驟 1 中生成的映射表
const classNameMap = require('./classNameMap.json');

const isProd = process.env.prod === 'true';
const enableOfBundleSize = false;
const enableSourceMap = false;

console.log('--- WEBPACK BUILD INFO ---');
console.log('NODE_ENV:', process.env.NODE_ENV ?? 'not set');
console.log('isProd Variable:', isProd);
console.log('---------------------------');
/** console.log(`有哪些環境變數可以用：\n`,process.env); */

// 建立一個給 string-replace-loader 使用的替換規則陣列
const replacements = [];
// \b (Word Boundary) 確保只匹配完整的字詞
for (const [longName, shortName] of Object.entries(classNameMap)) {
    const searchRegex = new RegExp('\\b' + longName + '\\b', 'g');
    replacements.push({
    search: searchRegex,
    replace: shortName,
    flags: 'g',
  });
}

const stringReplaceLoader = {
    loader: 'string-replace-loader',
    options: {
        multiple: replacements
    }
};

const config = {
  entry: {
    main: path.resolve(__dirname, "./src/index.js"),
  },
  output: {
    path: path.resolve(__dirname, "./dist"),
    filename: "[name].[contenthash:8].js",
    assetModuleFilename: "[name][ext]",
    clean: true,
    publicPath: "/", // 確保 Firebase 能正確載入資源
  },
  optimization: {
      splitChunks: {
      chunks: 'all',
      cacheGroups: {
        mui: {
          test: /[\\/]node_modules[\\/]@mui[\\/]/,
          name: 'mui',
          chunks: 'all',
        },
        lodash: {
          test: /[\\/]node_modules[\\/]lodash[\\/]/,
          name: 'lodash',
          chunks: 'all',
        },
      },
  },
  },
  watchOptions: {
    aggregateTimeout: 200,
    poll: 1000,
    ignored: /node_modules/,
  },
  module: {
    rules: [
      {
        test: /\.(js|jsx)$/,
        exclude: /node_modules/,
        use: [
          stringReplaceLoader,
          {
            loader: "babel-loader",
            options: {
              presets: [["@babel/preset-env", { targets: "defaults" }], "@babel/preset-react"],
              plugins: [
                ["@babel/plugin-proposal-decorators", { legacy: true }],
                ["@babel/plugin-transform-class-properties", { loose: true }],
                "@babel/plugin-transform-runtime",
              ],
            },
          },
        ],
      },
      {
        test: /\.css$/,
        oneOf: [
          {
            test: /\.module\.css$/,
            use: [
              isProd ? MiniCssExtractPlugin.loader : "style-loader",
              {
                loader: "css-loader",
                options: {
                  modules: {
                    localIdentName: isProd ? "[hash:base64:6]" : "[path][name]__[local]",
                  },
                },
              },
              stringReplaceLoader
            ],
          },
          {
            use: [
              isProd ? MiniCssExtractPlugin.loader : "style-loader",
              "css-loader",
              stringReplaceLoader,
            ],
          },
        ],
      },
      {
        test: /\.(svg|ico|png|webp|jpg|gif|jpeg)$/,
        type: "asset/resource",
      },
    ],
  },
  resolve: {
    alias: {
      'inquirer': false,
      'winston': false,
      '@inquirer/core': false,
      '@inquirer/checkbox': false,
      '@inquirer/prompts': false
    },
    extensions: [".js", ".jsx", ".css"],
    fallback: {
      fs: false,
      child_process: false,
      path: require.resolve("path-browserify"),
      buffer: require.resolve("buffer/"),
      url: false,
      http: false,
      https: false,
      zlib: false,
      assert: false,
      util: false,
      stream: false,
      constants: false,
      events: false,
      os: false,
      readline: false,
      crypto: false,
      tty: false,
      async_hooks: false
    },
  },
  target: ["web"],
  plugins: [
    new HtmlWebpackPlugin({
      template: "template.html",
      filename: "index.html",
      title: "{{titleOfProject}}",
      inject: "body",
    }),
    new webpack.IgnorePlugin({
      resourceRegExp: /^\.\/.+/,
      contextRegExp: /winston|nodeutiller/,
    }),
    new webpack.DefinePlugin({
      process: {
        env: {
          is_node: false,
          self_debug: !isProd,
        },
      },
    }),
    new webpack.NormalModuleReplacementPlugin(/^node:/, (resource) => {
       resource.request = resource.request.replace(/^node:/, "");
    }),
  ]
};

if (isProd) {
  config.mode = "production";
  config.devtool = false; // 再次確認關閉 SourceMap
  Object.assign(config.optimization, {
      minimize: true,
      minimizer: [
          new TerserPlugin({
              // ⚠️ 關鍵：確保 Terser 插件的配置是針對應用程式程式碼
              terserOptions: {
                  // ... (其他設置保留)
                  compress: {
                      // ... (其他 compress 設置保留)
                      drop_console: true,
                      pure_funcs: ["console.log", "console.info", "console.debug"],
                      drop_debugger: true,
                      unused: true,      // 刪除未使用的變數/函數
                      dead_code: true,    // 刪除不可達的代碼
                  },

                  // ✨ 核心混淆設定：強制重新命名函式和類別名稱
                  // 這將把所有具名函式和類別名替換為 'a', 'b', 'c' 等單字母。
                  keep_classnames: false, // <-- 移除 Class 名稱 (解決 class A {})
                  keep_fnames: false,     // <-- 移除 Function 名稱 (解決 function funcA {})
                  mangle: true,
                  output: {
                      // 需求 1: 減少體積 (移除所有註釋)
                      comments: false,
                  },
              },
              extractComments: false,
          }),
    ],
    sideEffects: true,
    usedExports: true, // 保持現有配置

    // ===================================================
    // ✨ 核心優化：程式碼拆分 (Code Splitting)
    // ===================================================
    splitChunks: {
        chunks: 'all', // 對所有 chunk 進行優化 (async 和 initial)
        minSize: 20000, // 模組超過 20kb 才拆分
        maxInitialRequests: 20, // 初始載入時最多允許 20 個請求
        maxAsyncRequests: 25, // 非同步載入時最多允許 25 個請求
        cacheGroups: {
            // 1. 核心框架 (Core Frameworks): 穩定且變動少
            // 確保 React 和 MobX 等核心框架在一個獨立的小 bundle
            framework: {
                chunks: 'all',
                name: 'framework', // 輸出檔案名為 framework.xxxxx.js
                test: /[\\/]node_modules[\\/](react|react-dom|mobx|mobx-react)[\\/]/,
                priority: 40, // 優先級最高
                enforce: true, // 即使不符合其他條件也強制創建
            },
            // 2. Material UI (MUI): 大型 UI 函式庫
            // 將所有 @mui/ 相關函式庫集中打包
            mui: {
                chunks: 'all',
                name: 'mui',
                test: /[\\/]node_modules[\\/](@mui)[\\/]/,
                priority: 30,
            },
            // 3. 第三方函式庫 (General Vendors): 其他 node_modules 依賴
            defaultVendors: {
                chunks: 'all',
                name: 'vendors',
                test: /[\\/]node_modules[\\/]/,
                priority: 20, // 優先級較低，讓 framework 和 mui 優先
                reuseExistingChunk: true,
            },
            // 4. 應用程式公用程式 (App Chunks): 您的 src/ 程式碼
            default: {
                minChunks: 2, // 至少被兩個以上的檔案引用才打包
                priority: 10,
                reuseExistingChunk: true,
            },
        },
    },
});

  config.plugins.push(
    new MiniCssExtractPlugin({
      filename: "[name].[contenthash:8].css",
      chunkFilename: "[id].[contenthash:8].css",
    }),
    new CompressionPlugin({
        test: /\.(js|css|html|svg)$/,
        filename: '[path][base].gz',
        algorithm: 'gzip',
        threshold: 10240, // 只壓縮超過 10KB 的檔案
        minRatio: 0.8,
    })
  );
} else {
  config.mode = "development";
  config.devtool = enableSourceMap ? "inline-source-map" : false;
  config.devServer = {
    static: {
      directory: path.resolve(__dirname, "./dist"),
    },
    port: 8080,
    open: true,
    hot: true,
    host: "0.0.0.0",
    allowedHosts: 'all',
    historyApiFallback: true,
    client: {
      webSocketURL: 'auto://0.0.0.0:0/ws',
      overlay: {
        warnings: false,
        runtimeErrors: (error) => {
          if (error?.message.includes("ResizeObserver")) {
            console.warn("ResizeObserver error suppressed");
            return false;
          }
          return true;
        },
      },
    },
  };

  config.plugins.push(new webpack.HotModuleReplacementPlugin());

  if (enableOfBundleSize) {
    config.plugins.push(
      new BundleAnalyzerPlugin({
        analyzerMode: "server",
        analyzerPort: 8866,
        openAnalyzer: true,
        reportFilename: "report.html",
      })
    );
  }
}

module.exports = config;
