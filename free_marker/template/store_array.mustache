    @action
    clean{{{functionName}}}(){
    this.{{{fieldName}}}.length = 0;
    }

    @action
    push{{{functionName}}}(...items) {
    const self = this;
    const itemsOfSorted = self.ruleOfPreviouslySort(items);
    this.{{{fieldName}}}.push(...itemsOfSorted.map((each) => each instanceof {{{fieldClass}}} ? each : new {{{fieldClass}}}({...each,parentNode:self})));
    self.invalidate();
    }

    @action
    push{{{functionName}}}ByIndex(index, ...params) {
    const self = this;
    const itemsOfSorted = self.ruleOfPreviouslySort(params);
    Util.insertToArray(this.{{{fieldName}}},index, ...itemsOfSorted.map((each) => each instanceof {{{fieldClass}}} ? each : new {{{fieldClass}}}({...each,parentNode:self})));
    self.invalidate();
    }

    @action
    updateSpecific{{{functionName}}}(latest, attr = 'id') {
        const {{{name}}} = _.find(this.get{{{functionName}}}(), ({{{name}}}) => _.isEqual({{{name}}}[attr], latest[attr]));
        messageX ? {{{name}}}.initial(latest) : this.push{{{functionName}}}ByIndex(-1, latest)
    }

    push{{{fieldClass}}} = (item = {}) => {
    this.push{{{functionName}}}(item);
    }

    @action
    remove{{{functionName}}}ByIndex(...indexes) {
    for (const index of indexes) {
    if (index < -1 && this.{{{fieldName}}}.length < index) {
    Util.appendError(`7821, index ${index} is not valid length ==>`, this.{{{fieldName}}}.length, `index ==>`, index);
    return;
    }
    }
    _.pullAt(this.{{{fieldName}}}, indexes);
    }

    @action
    remove{{{functionName}}}(...fatefulItems) {
    const indexes = [];
    for (const item of fatefulItems) {
    indexes.push(_.indexOf(this.{{{fieldName}}}, item));
    }
    this.remove{{{functionName}}}ByIndex(...indexes);
    }
