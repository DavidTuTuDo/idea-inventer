{{#hasPaginate}}
    next{{{fieldClass}}}PageMode = 'paging';//['in-array','paging']

    {{{name}}}NextIds = [];

    lastItemOf{{{fieldClass}}} = undefined;

    pushNext{{{fieldClass}}}IDs= (...ids)=> {
    this.{{{name}}}NextIds.push(...ids);
    this.next{{{fieldClass}}}PageMode = 'in-array';
    }

    clean{{{fieldClass}}}NextIds() {
    this.{{{name}}}NextIds.length = 0
    }

    getNext{{{fieldClass}}}IDs =() => {
    return this.{{{name}}}NextIds;
    }

    getNext{{{fieldClass}}}PageMode =() => {
    return this.next{{{fieldClass}}}PageMode;
    }

    setNext{{{fieldClass}}}PageMode = (mode) => {
    this.next{{{fieldClass}}}PageMode =  mode;
    }

    fetch{{{functionName}}} = async ({{{stringOfParamInFetch}}}) => {
    const self = this;
    const fatefulItems = [];
    switch (self.getNext{{{fieldClass}}}PageMode()) {
    case "in-array":
    const itemsOfNextIds = await self.fetch{{{fieldClass}}}ByNextIds({{{stringOfArgumentInFetch}}});
    fatefulItems.push(...itemsOfNextIds);
    break;
    case "paging":
    const itemsOfNextPage = await self.fetch{{{fieldClass}}}NextPageItems({{{stringOfArgumentInFetch}}});
    this.lastItemOf{{{fieldClass}}} = _.last(itemsOfNextPage);
    fatefulItems.push(...itemsOfNextPage);
    break;
    default:
    const queryItems = await new {{{fieldClass}}}().fetch(
    {{{stringOfArgumentInFetch}}},
    ...this.get{{{fieldClass}}}Conditions()
    )
    fatefulItems.push(...queryItems)
    break;
    }

    if(_.size(fatefulItems) < {{{fieldClass}}}.sizeOfPerPage) {
    this.setHasNextPageBehavior(false);
    }

    this.push{{{functionName}}}(...fatefulItems);
    return fatefulItems;
    };

    fetch{{{fieldClass}}}NextPageItems = async ({{{stringOfParamInFetch}}}) => {
    const conditionsOfNext = this.getStartAfterConditions(this.lastItemOf{{{fieldClass}}});
    const fatefulItems = await new {{{fieldClass}}}().fetch(
    {{{stringOfArgumentInFetch}}},
    ...this.get{{{fieldClass}}}Conditions(),
    ...conditionsOfNext
    );
    return fatefulItems;
    }

    fetch{{{fieldClass}}}ByNextIds = async ({{{stringOfParamInFetch}}}) => {
    const self = this;
    const targets = _.remove(self.getNext{{{fieldClass}}}IDs(), (each, index) => {
    return index < {{{fieldClass}}}.sizeOfPerPage;
    })
    if (!_.isEmpty(targets)) {
    return await new {{{fieldClass}}}().fetch(
    {{{stringOfArgumentInFetch}}},
    ...this.getInArrayConditions(targets),
    ...this.get{{{fieldClass}}}Conditions()
    );
    }
    return [];
    }

