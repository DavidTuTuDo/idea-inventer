{{#hasPaginate}}
    next{{{fieldClass}}}PageMode = 'paging';//['in-array','paging']

    {{{name}}}Ids = [];

    pushNext{{{fieldClass}}}IDs= (...ids)=> {
    this.{{{name}}}Ids.push(...ids);
    this.next{{{fieldClass}}}PageMode = 'in-array';
    }

    getNext{{{fieldClass}}}IDs =() => {
    return this.{{{name}}}Ids;
    }

    getNext{{{fieldClass}}}PageMode =() => {
    return this.next{{{fieldClass}}}PageMode;
    }

    setNext{{{fieldClass}}}PageMode = (mode) => {
    this.next{{{fieldClass}}}PageMode =  mode;
    }

    fetchNextPage{{{functionName}}} = (view) => {
    const self = this;
    return async () => {
    const items = [];
    switch (self.getNext{{{fieldClass}}}PageMode()) {
    case "in-array":
    const itemsOfNextIds = await self.fetch{{{fieldClass}}}ByNextIds(view);
    items.push(...itemsOfNextIds);
    break;
    default:
    const itemsOfNextPage = await self.fetch{{{fieldClass}}}NextPageItems(view);
    items.push(...itemsOfNextPage);
    }
    this.push{{{functionName}}}(...items);
    };
    }

    fetch{{{fieldClass}}}NextPageItems = async (view) => {
    const last = _.last(this.get{{{functionName}}}());
    if (_.isEmpty(last)) return [];
    const doc = last.getDocRef();
    const items = await new {{{fieldClass}}}().fetch(
    view,
    {startAfter:(stmt) => stmt.startAfter(doc)},
    ...this.get{{{fieldClass}}}Conditions()
    );
    return items;
    }

    fetch{{{fieldClass}}}ByNextIds = async (view) => {
    const self = this;
    const targets = _.remove(self.getNext{{{fieldClass}}}IDs(), (each, index) => {
    return index < 10;
    })
    if (_.isArray(targets) && !_.isEmpty(targets)) {
    return await new {{{fieldClass}}}().fetch(
    view,
    {where: (stmt) => stmt.where(self.getFieldNameOfDocumentId(), "in", targets)},
    ...this.get{{{fieldClass}}}Conditions()
    );
    }
    return [];
    }

    fetch{{{functionName}}} = async (view) => {
    const self = this;
    switch (self.getNext{{{fieldClass}}}PageMode()) {
    case 'in-array':
    return await self.fetch{{{fieldClass}}}ByNextIds();
    default:
    return await new {{{fieldClass}}}().fetch(
    view,
    ...this.get{{{fieldClass}}}Conditions()
    )
    }
    }
{{/hasPaginate}}

