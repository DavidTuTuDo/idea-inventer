const edit = true;
/** 2024.11.16 想做成module結果沒時間想細部邏輯，未來也只想賣模組過的產品，暫時先不擔心這的元件會被reuse */
import {observer} from "mobx-react";
import Style from "../style";
import React from "react";
import IconButton from "@mui/material/IconButton";
import TextField from "@mui/material/TextField";
import _ from "lodash";
import MuiComponent from "./MUIComponent";
import {action, makeObservable, observable} from "mobx";
import AlertDialog from "./AlertDialog";


class OrderCountStore {

    @observable
    countOfMaxHeap = false;

    @observable
    countOfCurrent = false;

    getCountOfSubmitDisabled() {
        return this.countOfSubmitDisabled;
    }

    @action
    removeCountOfSubmitDisabled() {
        this.countOfSubmitDisabled = false;
    }

    @action
    toggleCountOfSubmitDisabled() {
        this.setCountOfSubmitDisabled(!this.getCountOfSubmitDisabled());
    }

    @action
    setCountOfSubmitDisabled(param) {
        if (param !== undefined) {
            this.countOfSubmitDisabled = param;
        } else {
            this.countOfSubmitDisabled = false;
        }
    }

    getCountOfSubmit() {
        return this.countOfSubmit;
    }

    @action
    removeCountOfSubmit() {
        this.countOfSubmit = 1;
    }

    @action
    setCountOfSubmit(param) {
        if (param !== undefined) {
            this.countOfSubmit = param;
        } else {
            this.countOfSubmit = 1;
        }
    }

    validateCountOfOrder(increase = true) {
        if(this.getIndexOfSelected() < 0) {
            this.getComponent().showWarningSnackMessage(`尚未選擇商品`)
            return;
        }

        const current = _.toNumber(this.getCountOfSubmit());
        if(increase) {
            const result = _.sum([current,1]);
            this.setCountOfSubmit(current > this.getCount() ? current : result)
        }else {
            const result = _.sum([current,-1]);
            this.setCountOfSubmit(current < 2 ? current : result)
        }
    }

}

@observer
class OrderCountView extends MuiComponent {

    constructor(props) {
        super(props);
        this.store = new OrderCountStore();
        this.value = props.value;
        this.maxHeap = props.maxHeap;
    }

    getStore(){
        return this.store;
    }

    MaenadsDecisionSetView = observer(({ maenads }) => {
        const self = this;
        const classes = this.propsMobX().classes;
        const MaenadsDecisionSetDecreaseView = self.MaenadsDecisionSetDecreaseView;
        const MaenadsDecisionSetCountOfSubmitView = self.MaenadsDecisionSetCountOfSubmitView;
        const MaenadsDecisionSetIncreaseView = self.MaenadsDecisionSetIncreaseView;
        return (
            <div className={"MaenadsDecisionSetDivWrap"} style={{ ...{}, ...Style.MaenadsDecisionSetDivWrap }}>
                <div className={"MaenadsDecisionSetDiv"} style={{ ...{}, ...Style.MaenadsDecisionSetDiv }}>
                    <MaenadsDecisionSetDecreaseView maenads={maenads} />

                    <MaenadsDecisionSetCountOfSubmitView maenads={maenads} />

                    <MaenadsDecisionSetIncreaseView maenads={maenads} />
                </div>
            </div>
        );
    });

    MaenadsDecisionSetDecreaseView = observer(({ maenads }) => {
        const self = this;
        const classes = this.propsMobX().classes;
        const objectOfParam = { object: maenads }; /** {object,view} */
        const MaenadsDecisionSetDecreaseIconView = self.MaenadsDecisionSetDecreaseIconView;
        return (
            <IconButton
                className={"MaenadsDecisionSetDecreaseIconButton"}
                onClick={(event, value) => {
                    objectOfParam.view = event;
                    self.onMaenadsDecreaseIconButtonClicked(objectOfParam);
                }}
                style={{ ...{}, ...Style.MaenadsDecisionSetDecreaseIconButton }}
            >
                <MaenadsDecisionSetDecreaseIconView />
            </IconButton>
        );
    });


    MaenadsDecisionSetCountOfSubmitView = observer(({ maenads }) => {
        const self = this;
        const classes = this.propsMobX().classes;
        const objectOfParam = { object: maenads }; /** {object,view} */
        const countOfSubmit = self.getMaenadsCountOfSubmit(maenads);
        return (
            <TextField
                className={"MaenadsDecisionSetCountOfSubmitTextField"}
                disabled={maenads.getCountOfSubmitDisabled()}
                type={"number"}
                InputLabelProps={{ shrink: true }}
                size={"small"}
                value={countOfSubmit}
                onChange={(event, value) => {
                    objectOfParam.view = event;
                    const latestValue = _.toNumber(self.getLatestValueByEvent(event));
                    maenads.setCountOfSubmit(latestValue);
                    self.onMaenadsCountOfSubmitTextFieldChange(objectOfParam);
                }}
                style={{ ...{}, ...Style.MaenadsDecisionSetCountOfSubmitTextField }}
                variant={"outlined"}
            />
        );
    });

    MaenadsDecisionSetIncreaseView = observer(({ maenads }) => {
        const self = this;
        const classes = this.propsMobX().classes;
        const objectOfParam = { object: maenads }; /** {object,view} */
        const MaenadsDecisionSetIncreaseIconView = self.MaenadsDecisionSetIncreaseIconView;
        return (
            <IconButton
                className={"MaenadsDecisionSetIncreaseIconButton"}
                onClick={(event, value) => {
                    objectOfParam.view = event;
                    self.onMaenadsIncreaseIconButtonClicked(objectOfParam);
                }}
                style={{ ...{}, ...Style.MaenadsDecisionSetIncreaseIconButton }}
            >
                <MaenadsDecisionSetIncreaseIconView />
            </IconButton>
        );
    });

    render = () => {
        const MaenadsDecisionSetView = this.MaenadsDecisionSetView;
        return <MaenadsDecisionSetView maenads={this.getStore()} />
    }

    onMaenadsIncreaseIconButtonClicked(param) {
        this.getStore().validateCountOfOrder();

    }

    onMaenadsDecreaseIconButtonClicked(param) {
        this.getStore().validateCountOfOrder(false);
    }
}

export default OrderCountView;
